# ──────────────────────────────────────────────
# Docmail configuration
# Copy this file to ~/docmail.conf and fill in your values
# chmod 600 ~/docmail.conf
# ──────────────────────────────────────────────

# ── Local paths ──────────────────────────────

# Base directory for documents. The installer creates queue/, sent/, failed/ inside it.
DOCMAIL_HOME="/path/to/docmail"

# Directory containing the DOCMAIL_TOKEN file (bare value, no KEY= prefix)
DOCMAIL_SECRETS_DIR="/path/to/secrets"

# ── Webhook ──────────────────────────────────

# Full URL of your webhook endpoint (n8n, Node-RED, a tiny Flask app... anything
# that accepts the JSON POST and sends the email).
DOCMAIL_WEBHOOK_URL="https://your-n8n-host.example.com/webhook/docmail"

# ── n8n server paths (only if you use the bundled n8n workflows) ─────────────

# Directory on the n8n server where documents are stored
# This must match the path used in the n8n workflow Code nodes
N8N_DOCMAIL_DIR="/home/node/docmail"

# ── SMTP (n8n credentials) ───────────────────

# n8n SMTP credential ID (find in n8n > Settings > Credentials)
# Used in workflow JSON files — update after importing
N8N_SMTP_CREDENTIAL_ID="your-smtp-credential-id"
N8N_SMTP_CREDENTIAL_NAME="SMTP account"

# ── Optional ─────────────────────────────────

# Extra voice definitions file for personality modes (leave empty to use the
# built-in table in the skill)
DOCMAIL_VOICE_DEFS=""

# Timezone for the morning recap cron (IANA format)
DOCMAIL_TIMEZONE="Europe/Paris"

# Recap schedule hour (24h format)
DOCMAIL_RECAP_HOUR="8"
